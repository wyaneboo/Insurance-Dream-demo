# Gemini credentials (any one of these is picked up, same order as the backend)
AI_API_KEY="your_google_gemini_api_key"
GOOGLE_API_KEY=""
GEMINI_API_KEY=""
AI_MODEL="gemini-2.5-flash"

# Where the Node backend is reachable (it owns the database + auth scoping)
BACKEND_URL="http://localhost:4000"

# Must match AI_INTERNAL_SECRET in the backend's .env
AI_INTERNAL_SECRET="dev_internal_secret"

# Port this Python service listens on
PORT=8000
